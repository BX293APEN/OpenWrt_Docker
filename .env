# docker-compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=openwrt            # プロジェクト名(全て小文字)
CONTAINER_NAME=openwrt-dev

Dockerfile_DIR=.
Dockerfile=Dockerfile

VOLUME=./linux_data

ENTRY_DIR=Programs
ENTRY_POINT=start.sh

PASSWORD=password

NETWORK_NAME=ethd
IP_SUBNET_ADDR=192.168.100.0
IP_PREFIX=24
IP_GATEWAY_ADDR=192.168.100.1