# =============================================================================
# OpenWrt Docker ビルド環境 - 環境変数設定
# このファイルを編集してください。スクリプト本体は変更不要です。
# =============================================================================

# ── Docker / Compose 設定 ──────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=openwrt_project   # プロジェクト名(全て小文字)
CONTAINER_NAME=Docker_OpenWrt

Dockerfile_DIR=.
Dockerfile=Dockerfile

ENTRY_DIR=Programs
ENTRY_POINT=openwrt_docker.sh

VOLUME=./build
WS=build

CPU_CORE=4

# ── OpenWrt バージョン・アーキテクチャ ────────────────────────────────────
# ImageBuilder を使用します
# https://downloads.openwrt.org/releases/ で最新バージョンを確認
OPENWRT_VERSION=25.12.1
EXT=tar.zst

# ── デバイスプロファイル ───────────────────────────────────────────────────
# 以下のどれかを設定してください。TARGET/SUBTARGET/PROFILE は自動で決まります。
#
#   x86_64        … PC / VM / USB (x86 64bit)          ← デフォルト
#   rpi4          … Raspberry Pi 4 / 400 / CM4
#   rpi3          … Raspberry Pi 3 / 3B+ / CM3
#   rpi2          … Raspberry Pi 2
#
DEVICE_PROFILE=x86_64

# ── ターゲット手動上書き(通常は変更不要) ────────────────────────────────
# DEVICE_PROFILE を設定した場合は以下を空欄にしてください。
# 特殊なターゲット(ath79/generic 等)を使いたい場合のみ直接記入します。
TARGET=
SUBTARGET=
PROFILE=

# ── ネットワーク設定(エントリーポイントに渡される) ───────────────────────
NTP_SERVER=192.168.10.64

# LAN側IPアドレス(OpenWrtのデフォルトゲートウェイIPになる)
LAN_IP=192.168.1.1
LAN_NETMASK=255.255.255.0
LAN_GATEWAY=192.168.1.254       # 上流ルーターのIP(PPPoE等の場合は不要)
LAN_DNS=8.8.8.8,8.8.4.4

# WAN側設定 (dhcp / static / pppoe)
WAN_PROTO=static
# WAN_PROTO=static の場合は以下も設定
WAN_IP=192.168.10.65
WAN_NETMASK=255.255.255.0
WAN_GATEWAY=192.168.10.1
DNS_SERVER=192.168.10.64,192.168.10.99
# WAN_PROTO=pppoe の場合は以下も設定
PPPOE_USER=
PPPOE_PASS=

# ── NICインターフェース自動検出 ────────────────────────────────────────────
# 起動時にNICを自動判別します。優先順位:
#   1. ネットワークアドレス条件 (WAN_NETWORK)
#   2. WAN接続優先 (デフォルトルートを持つNICをWANとみなす)
#   3. インターフェース名指定 (WAN_IFACE / LAN_IFACE)
#
# WAN_NETWORK: WANが属するサブネットを CIDR で指定 (例: 192.168.10.0/24)
#              指定するとそのネットワークにIPを持つNICをWANとして自動選択します
#              空欄の場合はデフォルトルート優先、さらに失敗するとフォールバックへ
WAN_NETWORK=192.168.10.0/24
#
# フォールバック用インターフェース名 (自動検出が全て失敗した場合に使用)
WAN_IFACE=eth0
LAN_IFACE=eth1

# ── ロケール・タイムゾーン ─────────────────────────────────────────────────
TIME_ZONE=Asia/Tokyo
# OpenWrtのtzdata形式 (luci-app-uhttpd等で確認可能)
OPENWRT_TZ=JST-9

# ── SSH設定 ───────────────────────────────────────────────────────────────
SSH_PORT=22

# WAN側からのSSH接続を許可するか (true / false)
# ⚠️  true にすると外部インターネットからSSH接続できます
# ⚠️  実験・一時利用目的のみ。本番環境では false を推奨
# ⚠️  強いパスワードを設定してください(ROOT_PASSWORD を変更)
WAN_SSH=true

# WAN SSH 許可時に接続元IPを絞る(空欄 = 制限なし)
# 例: WAN_SSH_ALLOW_IP=203.0.113.10  ← 自分の固定IPなど
WAN_SSH_ALLOW_IP=192.168.10.50

# ── rootパスワード ────────────────────────────────────────────────────────
ROOT_PASSWORD=password

# ── ミラーサーバー ────────────────────────────────────────────────────────
OPENWRT_MIRROR=https://downloads.openwrt.org
